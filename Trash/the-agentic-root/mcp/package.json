{
  "name": "@bxthre3/agentic-mcp",
  "version": "1.0.0",
  "description": "Agentic MCP Server - Full access to Agentic for MCP clients",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dev:mesh": "tsx src/index.ts --mesh",
    "dev:http": "tsx src/index.ts --http",
    "start": "node dist/index.js",
    "start:mesh": "node dist/index.js --mesh",
    "start:http": "node dist/index.js --http"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
