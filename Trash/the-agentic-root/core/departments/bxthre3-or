    ],
    employees: ['maya', 'builder-1', 'builder-2', 'builder-3'],
    output: 'Working MVP + pilot results + business case',
    metrics: {
      projectsInBuild: 0,
      avgBuildDuration: 180, // days
      pmfRate: 0.6 // 60% show PMF signals
    }
  };
  
  // 4. PORTFOLIO OPS — Manage active holdings
  readonly portfolioOps = {
    name: 'Portfolio Operations',
    function: 'Manage active projects, track spin-off readiness',
    process: [
      'Quarterly portfolio review',
      'Spin-off readiness assessment (team, revenue, systems)',
      'Resource allocation across portfolio',
      'Decision: spin off, sell, or archive'
    ],
    employees: ['drew', 'portfolio-manager', 'finance-analyst'],
    output: 'Portfolio dashboard + spin-off recommendations',
