    }
  };
  
  // 5. COMMERCIALIZATION — Prepare for spin-off or sale
  readonly commercialization = {
    name: 'Commercialization',
    function: 'Package projects for spin-off or strategic sale',
    process: [
      'Subsidiary entity formation (if spinning off)',
      'Team transition planning',
      'IP transfer and licensing',
      'Investor materials (if raising for spin-off)',
      'Strategic buyer identification (if selling)'
    ],
    employees: ['drew', 'jordan', 'legal-counsel'],
    output: 'Spin-off ready entity or sale package',
    metrics: {
      projectsInCommercialization: 0,
      spinoffsCompleted: 0,
      strategicSales: 0
    }
  };
  
  // 6. ARCHIVE — Graceful wind-down
  readonly archive = {
    name: 'Archive',
    function: 'Graceful wind-down and knowledge capture',
    process: [
      'Capture learnings and IP',
      'Secure data and systems',
      'Team reassignment or exit',
      'Public post-mortem (what we learned)'
    ],
    employees: ['drew', 'knowledge-manager'],
    output: 'Archived project + lessons learned',
    metrics: {
      archivedProjects: 0,
      lessonsDocumented: 0
    }
  };
  
  // Project flow through departments
  moveProject(projectId: string, toStage: ProjectLifecycle['stage']): void {
    const project = this.projects.get(projectId);
    if (!project) return;
    
    const fromStage = project.stage;
    project.stage = toStage;
    
    // Update department mapping
    const deptMap: Record<string, string> = {
      'ideation': 'Ideation Lab',
      'research': 'Deep Research',
      'build': 'Build Studio',
      'portfolio': 'Portfolio Ops',
      'spinoff': 'Commercialization',
      'sold': 'Commercialization',
      'archived': 'Archive'
    };
    project.department = deptMap[toStage];
    
    eventBus.publish(BXTHRE3_EVENTS.PROJECT_STAGE_CHANGE, 'departments', {
      projectId,
      from: fromStage,
      to: toStage,
      department: project.department
    }, 'normal');
    
    console.log(`[DEPT] ${projectId}: ${fromStage} → ${toStage}`);
  }
  
  // Health check all projects
  assessHealth(): Array<{
    projectId: string;
    stage: string;
    health: string;
    action: string;
  }> {
    return Array.from(this.projects.values()).map(p => {
      let action = 'continue';
      
      // Red flags
      if (p.metrics.timeToRevenue > 18) action = 'review';
      if (p.metrics.technicalRisk > 80) action = 'reassess';
      if (p.metrics.marketSize < 50 && p.stage !== 'archived') action = 'consider-archive';
      
      return {
        projectId: p.id,
        stage: p.stage,
        health: p.health,
        action
      };
    });
  }
  
  getPortfolioSummary(): {
    byStage: Record<string, number>;
    totalValue: number;
    spinoffReady: number;
    healthDistribution: Record<string, number>;
  } {
    const byStage: Record<string, number> = {};
    const healthDistribution: Record<string, number> = { green: 0, yellow: 0, red: 0 };
    let totalValue = 0;
    let spinoffReady = 0;
    
    for (const project of this.projects.values()) {
      byStage[project.stage] = (byStage[project.stage] || 0) + 1;
      healthDistribution[project.health]++;
      totalValue += project.metrics.marketSize;
      if (project.spinoffReadiness > 80) spinoffReady++;
    }
    
    return { byStage, totalValue, spinoffReady, healthDistribution };
  }
}

export const bxthre3Depts = new Bxthre3Departments();