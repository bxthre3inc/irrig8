// Bxthre3 Inc — R&D Studio + Holdings Company
// Department Structure for Venture Studio Model

import { org } from '../hierarchy/org.js';
import { eventBus, BXTHRE3_EVENTS } from '../events/bus.js';

export interface ProjectLifecycle {
  id: string;
  name: string;
  stage: 'ideation' | 'research' | 'build' | 'portfolio' | 'spinoff' | 'sold' | 'archived';
  department: string;
  health: 'green' | 'yellow' | 'red';
  metrics: {
    marketSize: number; // TAM in $M
    technicalRisk: number; // 0-100
    teamReadiness: number; // 0-100
    timeToRevenue: number; // months
  };
  spinoffReadiness: number; // 0-100
  subsidiaryId?: string; // If spun off
}

class Bxthre3Departments {
  private projects: Map<string, ProjectLifecycle> = new Map();
  
  // 1. IDEATION LAB — Generate and validate concepts
  readonly ideationLab = {
    name: 'Ideation Lab',
    function: 'Generate, validate, and prioritize new concepts',
    process: [
      'Weekly concept pitches (anyone can submit)',
      '72h rapid validation (market size, technical feasibility)',
      'Go/no-go gate: needs TAM >$100M + solvable technical risk'
    ],
    employees: ['alex', 'research-analyst-1', 'research-analyst-2'],
    output: 'Validated concepts ready for Deep Research',
    metrics: {
      conceptsGenerated: 0,
      validationRate: 0, // % that pass 72h gate
      avgTimeToValidation: 72 // hours
    }
  };
  
  // 2. DEEP RESEARCH — Technical and market validation
  readonly deepResearch = {
    name: 'Deep Research',
    function: 'Technical deep-dive and market validation (2-4 weeks)',
    process: [
      'Technical feasibility assessment',
      'Competitive landscape analysis',
      'Customer discovery (20+ interviews)',
      'IP landscape search',
      'Go/no-go gate: needs clear path to MVP in <6 months'
    ],
    employees: ['alex', 'casey', 'ip-specialist'],
