    metrics: {
      projectsInResearch: 0,
      avgResearchDuration: 21, // days
      goRate: 0.4 // 40% pass to build
    }
  };
  
  // 3. BUILD STUDIO — MVP development and prototyping
  readonly buildStudio = {
    name: 'Build Studio',
    function: 'Rapid MVP development and pilot execution',
    process: [
      '6-month sprint to working MVP',
      'Early pilot with 3-5 design partners',
      'Iterate based on feedback',
